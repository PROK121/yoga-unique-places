# Скопируйте в .env.local и подставьте значения. Файлы .env* с секретами не коммитьте.

# Сервер оплаты и поддержки (node server/telegram-support.mjs)
# Локально:
# VITE_SUPPORT_API_URL=http://127.0.0.1:8787
# Продакшен (Render и т.д.): публичный URL второго сервиса, например https://your-api.onrender.com
# Без слэша на конце.
VITE_SUPPORT_API_URL=http://127.0.0.1:8787

# Если на backend задан SUPPORT_API_SECRET — тот же секрет в клиенте:
# VITE_SUPPORT_API_SECRET=

# 2GIS: карта и геокод в админке
# VITE_2GIS_API_KEY=
